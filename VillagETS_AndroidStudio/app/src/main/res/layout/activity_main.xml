<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- TOP BAR -->

    <ImageView
        android:id="@+id/menuBtn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VillagETS"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/menuBtn"
        app:layout_constraintEnd_toStartOf="@id/addPostBtn"
        app:layout_constraintTop_toTopOf="@id/menuBtn"
        app:layout_constraintBottom_toBottomOf="@id/menuBtn"/>

    <ImageView
        android:id="@+id/addPostBtn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        app:layout_constraintEnd_toStartOf="@id/profileBtn"
        app:layout_constraintTop_toTopOf="@id/menuBtn"
        app:layout_constraintBottom_toBottomOf="@id/menuBtn"
        android:layout_marginEnd="12dp"/>

    <ImageView
        android:id="@+id/profileBtn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/menuBtn"
        app:layout_constraintBottom_toBottomOf="@id/menuBtn"/>


    <!-- POSTS AREA -->

    <ScrollView
        android:id="@+id/postScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/menuBtn"
        app:layout_constraintBottom_toTopOf="@id/homeBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/postContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#DDDDDD"
                android:gravity="center"
                android:text="Post"
                android:textSize="18sp" />

        </LinearLayout>

    </ScrollView>


    <!-- BOTTOM NAV -->

    <ImageButton
        android:id="@+id/homeBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@null"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/moneyBtn"
        app:layout_constraintBottom_toBottomOf="parent"

        app:layout_constraintHorizontal_chainStyle="packed"
        android:layout_marginBottom="12dp"/>

    <ImageButton
        android:id="@+id/moneyBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"

        android:layout_marginBottom="12dp"
        android:background="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/searchBtn"
        app:layout_constraintStart_toEndOf="@id/homeBtn" />

    <ImageButton
        android:id="@+id/searchBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"

        android:layout_marginBottom="12dp"
        android:background="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/messageBtn"
        app:layout_constraintStart_toEndOf="@id/moneyBtn" />

    <ImageButton
        android:id="@+id/messageBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"

        android:layout_marginBottom="12dp"
        android:background="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/notificationBtn"
        app:layout_constraintStart_toEndOf="@id/searchBtn" />

    <ImageButton
        android:id="@+id/notificationBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"

        android:layout_marginBottom="12dp"
        android:background="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/messageBtn" />

</androidx.constraintlayout.widget.ConstraintLayout>